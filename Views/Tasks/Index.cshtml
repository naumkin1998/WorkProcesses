@model List<WorkProcesses.Models.TaskItem>
@using WorkProcesses.Models
@using Microsoft.AspNetCore.Identity
@inject UserManager<AppUser> UserManager

@{
    ViewData["Title"] = "Задания";

    var currentUser = await UserManager.GetUserAsync(User);
}

<!-- Подключаем стили DataTables -->
<link rel="stylesheet" type="text/css" href="https://cdn.datatables.net/1.13.4/css/jquery.dataTables.min.css" />

<h1>Задания</h1>

<!-- Упрощённая форма фильтрации по дате (без лишних радиокнопок) -->
<div class="row mb-3">
    <div class="col-md-4">
        <form method="get" id="filterForm" class="d-flex flex-column gap-2">
            <div class="input-group">
                <input type="date" name="filterDate" id="filterDate" class="form-control" value="@ViewBag.FilterDate?.ToString("yyyy-MM-dd")" />
                <button type="submit" class="btn btn-primary">Применить</button>
                <a href="@Url.Action("Index")" class="btn btn-secondary">Сбросить</a>
            </div>
            <div class="btn-group" role="group">
                <button type="button" class="btn btn-sm btn-outline-secondary" onclick="setFilter('today')">Сегодня</button>
                <button type="button" class="btn btn-sm btn-outline-secondary" onclick="setFilter('week')">Неделя</button>
                <button type="button" class="btn btn-sm btn-outline-secondary" onclick="setFilter('month')">Месяц</button>
            </div>
        </form>
    </div>
</div>

@if (User.IsInRole("Admin") || User.IsInRole("ServiceHead") || User.IsInRole("DepartmentHead"))

{
        <a asp-action="Create" class="btn btn-primary mb-3">+ Новое задание</a>
        <a asp-action="ExportToExcel" class="btn btn-success mb-3">📊 Выгрузить все задания в Excel</a>
}

@if (TempData["Success"] != null)

{
        <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)

{
        <div class="alert alert-danger">@TempData["Error"]</div>
}

<!-- Таблица с фиксированным количеством колонок (7 информационных + 1 действия) -->
<table id="tasksTable" class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Название</th>
            <th>Кому</th>
            <th>Кто выдал</th>
            <th>Срок</th>
            <th>Тип</th>
            <th>Статус</th>
            <th>Отчётов</th>
            <th>Действия</th>   <!-- одна колонка для всех кнопок -->
        </tr>
    </thead>
    <tbody>
        @foreach (var task in Model)

        {
                <tr class="@(task.IsOverdue && !task.IsCompleted ? "table-danger" : "")">
                    <td>@task.Title</td>
                    <td>@(task.AssignedTo?.FullName ?? "—")</td>
                    <td>@(task.AssignedBy?.FullName ?? "—")</td>
                    <td>
                    @if (task.Deadline.Year >= 9998)

                    {
                                <span>Без срока</span>
                    }

                    else

                    {
                                <span>@task.Deadline.ToString("dd.MM.yyyy HH:mm")</span>
                    }
                    </td>
                    <td>
                    @if (task.TaskType == TaskType.Single)
                    {
                        <span>Разовое</span>
                    }

                    else if (task.TaskType == TaskType.Daily)
                    {
                        <span>Ежедневное</span>
                    }

                    else
                    {
                        <span>Еженедельное</span>
                    }
                    </td>
                    <td>
                    @if (task.IsCompleted)

                    {
                                <span class="badge bg-success">Выполнено</span>
                    }

                    else if (task.IsOverdue)

                    {
                                <span class="badge bg-danger">Просрочено</span>
                    }

                    else

                    {
                                <span class="badge bg-warning text-dark">В работе</span>
                    }
                    </td>
                    <td>@task.Reports.Count</td>
                    <td>
                        <div class="btn-group btn-group-sm" role="group">
                            <!-- Кнопка удаления (только для авторизованных) -->
                        @if (User.IsInRole("Admin") || User.IsInRole("ServiceHead") || (User.IsInRole("DepartmentHead") && task.Assignments.Any(a => a.AppUser.DepartmentId == currentUser.DepartmentId)))

                        {
                                    <form method="post" asp-action="Delete" asp-route-id="@task.Id" onsubmit="return confirm('Удалить задание?');" style="display:inline">
                                        <button type="submit" class="btn btn-danger">Удалить</button>
                                    </form>
                        }

                        else

                        {
                                    <!-- пустой элемент для сохранения структуры таблицы (можно просто &nbsp; или ничего) -->
                                    <span style="display:inline-block; width:60px;"></span>
                        }
                            <!-- Кнопка подробнее -->
                            <a asp-action="Details" asp-route-id="@task.Id" class="btn btn-info">Подробнее</a>
                        </div>
                    </td>
                </tr>
        }
    </tbody>
</table>

@if (!Model.Any())

{
        <div class="alert alert-info">Заданий пока нет.</div>
}

@section Scripts {
        <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
        <script>
            $(document).ready(function () {
                $('#tasksTable').DataTable({
                    "order": [[3, "desc"]],          // сортировка по колонке "Срок" (индекс 3) по убыванию
                    "language": {
                        "url": "//cdn.datatables.net/plug-ins/1.13.4/i18n/ru.json"
                    },
                    "columnDefs": [
                        { "orderable": false, "targets": [7] }  // колонка "Действия" не сортируемая
                    ]
                });
            });

            // Функция для упрощённой фильтрации (без лишних радиокнопок)
                function setFilter(type) {
        const form = document.getElementById('filterForm');
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = 'filterType';
        input.value = type;
        form.appendChild(input);
        form.submit();
    }
        </script>
}