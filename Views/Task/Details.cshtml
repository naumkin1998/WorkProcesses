@model WorkProcesses.Models.TaskItem
@using WorkProcesses.Models
@using Microsoft.AspNetCore.Identity
@inject UserManager<AppUser> UserManager

@{
    ViewData["Title"] = Model.Title;
    var currentUser = await UserManager.GetUserAsync(User);
    var canReport = !Model.IsCompleted && currentUser?.Id == Model.AssignedToId;
    var canApprove = !Model.IsCompleted && 
        (User.IsInRole("Admin") || 
         User.IsInRole("ServiceHead") || 
         (User.IsInRole("DepartmentHead") && Model.AssignedTo?.DepartmentId == currentUser?.DepartmentId) ||
         Model.AssignedById == currentUser?.Id);
}

<h1>@Model.Title</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="row">
    <div class="col-md-8">
        <div class="card mb-3">
            <div class="card-header bg-primary text-white">Информация о задании</div>
            <div class="card-body">
                <p><strong>Описание:</strong> @(string.IsNullOrEmpty(Model.Description) ? "—" : Model.Description)</p>
                <p><strong>Кому:</strong> @(Model.AssignedTo?.FullName ?? "—")</p>
                <p><strong>Кто выдал:</strong> @(Model.AssignedBy?.FullName ?? "—")</p>
                <p><strong>Срок:</strong> @Model.Deadline.ToString("dd.MM.yyyy HH:mm")</p>
                <p><strong>Тип:</strong> 
                    @if (Model.TaskType == TaskType.Single)
                    {
                        <span>Разовое</span>
                    }
                    else if (Model.TaskType == TaskType.Daily)
                    {
                        <span>Ежедневное</span>
                    }
                    else
                    {
                        <span>Еженедельное</span>
                    }
                </p>
                <p><strong>Статус:</strong>
                    @if (Model.IsCompleted)
                    {
                        <span class="badge bg-success">Выполнено</span>
                    }
                    else if (Model.IsOverdue)
                    {
                        <span class="badge bg-danger">Просрочено</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">В работе</span>
                    }
                </p>
            </div>
        </div>

        @if (canReport)
        {
            <div class="card mb-3">
                <div class="card-header bg-success text-white">Сдать отчёт</div>
                <div class="card-body">
                    <form method="post" asp-action="AddReport">
                        <input type="hidden" name="taskId" value="@Model.Id" />
                        <div class="mb-3">
                            <label class="form-label">Дата отчёта</label>
                            <input type="date" name="forDate" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                            <small class="text-muted">Для ежедневных/еженедельных заданий — укажите дату</small>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Текст отчёта</label>
                            <textarea name="reportText" class="form-control" rows="3" required></textarea>
                        </div>
                        <button type="submit" class="btn btn-success">Сдать отчёт</button>
                    </form>
                </div>
            </div>
        }

        <div class="card">
            <div class="card-header">Отчёты по заданию</div>
            <div class="card-body">
                @if (Model.Reports.Any())
                {
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Дата отчёта</th>
                                <th>Сдал</th>
                                <th>Текст</th>
                                <th>Статус</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var report in Model.Reports.OrderByDescending(r => r.ReportedAt))
                            {
                                <tr>
                                    <td>@report.ForDate.ToString("dd.MM.yyyy")</td>
                                    <td>@(report.AppUser?.FullName ?? "—")</td>
                                    <td>@report.Text</td>
                                    <td>
                                        @if (report.IsApproved)
                                        {
                                            <span class="badge bg-success">Принят</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">На проверке</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!report.IsApproved && canApprove)
                                        {
                                            <form method="post" asp-action="ApproveReport" style="display:inline">
                                                <input type="hidden" name="reportId" value="@report.Id" />
                                                <button type="submit" class="btn btn-sm btn-primary">Принять</button>
                                            </form>
                                        }
                                    </td>
                                 </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted">Отчётов пока нет.</p>
                }
            </div>
        </div>
    </div>
</div>

<a asp-action="Index" class="btn btn-secondary mt-3">Назад к списку</a>